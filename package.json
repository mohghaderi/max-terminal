{
  "name": "max-terminal",
  "version": "0.1.0",
  "description": "Electron terminal layout with xterm.js and node-pty",
  "main": "src/main.js",
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w node-pty",
    "dist": "electron-builder --config electron-builder.config.json --publish=never"
  },
  "devDependencies": {
    "electron": "^40.0.0",
    "electron-rebuild": "^2.0.3",
    "electron-builder": "^26.4.0"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "split.js": "^1.6.5",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "volta": {
    "node": "24.13.0"
  }
}
