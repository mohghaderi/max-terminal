{
  "appId": "com.max-terminal.app",
  "productName": "max-terminal",
  "directories": {
    "output": "dist"
  },
  "files": [
    "src/**/*",
    "assets/**/*",
    "conf/**/*",
    "index.html",
    "package.json"
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "artifactName": "max_terminal_setup_${version}.exe"
      },
      {
        "target": "zip",
        "artifactName": "max_terminal_${version}.zip"
      }
    ]
  },
  "mac": {
    "target": [
      "dmg",
      "zip"
    ]
  },
  "linux": {
    "target": [
      "AppImage",
      "deb"
    ]
  }
}
